# ===========================================
# 账号管理系统 Docker 部署配置
# ===========================================
# 复制此文件为 .env 并根据需要修改配置

# ----- 域名配置 -----
# 部署域名，本地开发使用 localhost
# 生产环境填写实际域名，如: example.com
DOMAIN=localhost

# ----- 端口配置 -----
# 对外暴露的HTTP端口
APP_PORT=80

# 对外暴露的HTTPS端口（启用SSL时使用）
APP_SSL_PORT=443

# 后端API内部端口（容器内部使用，一般无需修改）
BACKEND_PORT=8998

# ----- SSL配置 -----
# 是否启用SSL/HTTPS (true/false)
SSL_ENABLED=false

# SSL证书路径（相对于deploy目录）
# SSL_CERT_PATH=./ssl/cert.pem
# SSL_KEY_PATH=./ssl/key.pem

# ----- 数据库配置 -----
# SQLite数据库文件路径（相对于backend目录）
DB_PATH=./accounts.db

# ----- 管理员配置 -----
# 管理员密码（生产环境请务必修改）
ADMIN_PASSWORD=admin121

# ----- 音乐API配置 -----
# 音乐API服务端点（逗号分隔，支持多个fallback端点）
# Docker环境默认: music-api:3000（内部服务名）,host.docker.internal:3000,外部IP:3000
# 直接部署默认: localhost:3000,127.0.0.1:3000,外部IP:3000
# 注意：优先使用Docker内部服务名以提高性能和可靠性
METING_API_URL=http://music-api:3000/,http://host.docker.internal:3000/

# ----- 网易云音乐Cookie配置 -----
# 网易云音乐Cookie（从浏览器复制，用于播放会员歌曲）
# 获取方法：
# 1. 浏览器登录 music.163.com
# 2. F12打开开发者工具 -> Application/存储 -> Cookies
# 3. 复制 MUSIC_U 的值（最重要）
# 格式: MUSIC_U=xxx; __csrf=yyy; 其他cookie...
NETEASE_COOKIE=_iuqxldmzr_=32; _ntes_nnid=96a33f2cd9e23388bebb11561256513d,1763365892419; _ntes_nuid=96a33f2cd9e23388bebb11561256513d; NMTID=00OtW5NrX3S61nrMkSsiSpCSo9_PXUAAAGakMw2gw; WEVNSM=1.0.0; WNMCID=fjsedk.1763365894895.01.0; WM_TID=Pw1GtuP8tc5BREEQBBPS2YNF4KUkH7x2; ntes_utid=tid._.9F8L0VcidIZAFhQRRVeWyZNA5KRwYMJP._.0; sDeviceId=YD-qeHc0vLR3I5BA0AUAFPWnZJF9bE1Nccl; __snaker__id=FDWoIRa6Rr3ebjZP; ntes_kaola_ad=1; timing_user_id=time_zMeIjob4LR; _ga=GA1.1.1777729360.1763391223; _ga_C6TGHFPQ1H=GS2.1.s1764039526$o2$g0$t1764039526$j60$l0$h0; _clck=7nv0xn%5E2%5Eg1b%5E0%5E2147; __csrf=2418fd066ca336e84eb438c4a0c245e5; JSESSIONID-WYYY=XaMoRC4h2yq2N1O7kswKMl2tHr%2B7EEJFJYir4%2F%5C8NgnVUry7czu8HmS%2BGjAdc9j9XTq5s7kxOIfXdfpkTvUCjCGDB3%2Bt7K%2Bj5mBQV95iKvE6%5CTt%2BmE8Pe%2FzjFulCCuVmYNGU%2FRzkE2jnS%2BE2JP0EF2%2FENA0XrRhjcM8xbh%2FFgGM%2B01We%3A1765120302256; WM_NI=0dyhg9pvRQFz%2F2NRLrLJHhsF4%2BskvbNFtA4LLNzzAZpvSZjdmrk6UUrpVfUxAUpoxUIQmXDTNr3HDw0uQskgsoFUsQVH38UXoZw%2Fqk%2Bu%2F7VyhiiY0O%2FhpCJLkv1k3a5RaWY%3D; WM_; gdxidpyhxdE=2%2BJTna%2F1pCsVXrEw9aBVYnUOAgYNUEASV1K3K%2BZx1icoV2vWixpsEdf8v7ii23wSYa2GUE8%2BknUlvIcYUlyMbSUL51C1pI%2FoQQdSRVWNTEehOxW4kPi6Ty%2BxRodx3bWqYeMuUbli6POY%2BfRmtJvQ1wMlLBxjwHwO1kQ%2FSJvJKR5hC76V%3A1765119405154; MUSIC_; __csrf=3ac9a59669de724a6740fc97f258d002

# NeteaseCloudMusicApi服务地址（用于Cookie刷新）
NETEASE_API_BASE=http://localhost:3000

# Cookie存储路径（相对于backend目录）
COOKIE_STORAGE_PATH=cookies/netease_cookies.json

# Cookie自动刷新间隔（小时，默认12小时刷新一次）
COOKIE_REFRESH_INTERVAL=12
